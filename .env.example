
DATABASE_URL="postgresql://postgres:mysecretpassword@localhost:5432/postgres?schema=public"

#Stripe API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Reconciliation endpoint secret (GET /api/reconcile?token=<this>)
RECONCILE_SECRET=local-dev-reconcile-secret

# Auth.js v5
AUTH_SECRET=...
AUTH_URL=http://localhost:3000

# Site URL (used for QR image links in emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

#Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev

# Seed configuration
# Set SEED_MODE=production to only create the admin user (skip demo data)
SEED_MODE=
# Admin user credentials (used in production seeding)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=password